# HorizonCover frontend configuration
# Copy to `.env.local` and fill in once contracts are deployed.

# Soroban RPC endpoint (defaults to public testnet RPC if omitted)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contract IDs (C...). Leave blank to run the UI in unconfigured mode.
VITE_CORE_CONTRACT_ID=
VITE_MONITOR_CONTRACT_ID=
VITE_USDC_CONTRACT_ID=
